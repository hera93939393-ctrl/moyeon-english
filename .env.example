# 이 파일을 복사해서 .env 로 만들고 실제 값을 채워주세요.
#   cp .env.example .env

# 솔라피(SOLAPI) SMS 설정 - solapi.com 콘솔 > API Key 관리에서 확인
SOLAPI_API_KEY=
SOLAPI_API_SECRET=
SOLAPI_SENDER=

# 알림 받을 원장님 번호 (하이픈 없이, 예: 01012345678)
OWNER_PHONE=

# 관리자 화면(/admin.html) 로그인 정보
ADMIN_USER=
ADMIN_PASSWORD=

# (선택) Claude API 키 - 채우면 AI 챗봇이 켜집니다
ANTHROPIC_API_KEY=

# (선택) 배포용 클라우드 DB(Neon 등) 연결 주소 - 비우면 로컬 SQLite 사용
DATABASE_URL=

PORT=3000
